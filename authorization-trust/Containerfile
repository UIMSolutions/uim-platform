# Multi-stage build for Authorization and Trust Management Service
# Compatible with Podman and Docker

# Stage 1: Build
FROM dlang2/ldc-ubuntu:1.40.1 AS builder

WORKDIR /app

COPY dub.sdl dub.selections.json ./
COPY source/ source/

RUN dub build --build=release --config=defaultRun

# Stage 2: Runtime
FROM ubuntu:24.04

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

RUN useradd --system --no-create-home appuser

WORKDIR /app

COPY --from=builder /app/build/uim-authorization-trust-platform-service .

USER appuser

EXPOSE 8116

ENV AUTHORIZATION_TRUST_HOST=0.0.0.0
ENV AUTHORIZATION_TRUST_PORT=8116

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8116/api/v1/health || exit 1

ENTRYPOINT ["./uim-authorization-trust-platform-service"]
