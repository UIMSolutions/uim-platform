# Multi-stage build for ABAP Compiler Service
# OCI-compliant — works with Podman (rootless) and Docker

# Stage 1: Build
FROM docker.io/dlang2/ldc-ubuntu:1.40.1 AS builder

WORKDIR /app

COPY dub.sdl dub.selections.json ./
COPY source/ source/

RUN dub build --build=release --config=defaultRun

# Stage 2: Runtime (minimal OCI image)
FROM docker.io/ubuntu:24.04

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

RUN useradd --system --no-create-home appuser

WORKDIR /app

COPY --from=builder /app/build/uim-abap-compiler-platform-service .

USER appuser

EXPOSE 8093

ENV ABAPCOMPILER_HOST=0.0.0.0
ENV ABAPCOMPILER_PORT=8093

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8093/api/v1/health || exit 1

ENTRYPOINT ["./uim-abap-compiler-platform-service"]
