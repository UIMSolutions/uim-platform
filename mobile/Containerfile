# Containerfile for Podman
# Mobile Services

# Stage 1: Build
FROM dlang2/ldc-ubuntu:1.40.1 AS builder

WORKDIR /app

COPY dub.sdl dub.selections.json ./
COPY source/ source/

RUN dub build --build=release --config=defaultRun

# Stage 2: Runtime
FROM ubuntu:24.04

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

RUN useradd --system --no-create-home appuser

WORKDIR /app

COPY --from=builder /app/build/uim-mobile-platform-service .

USER appuser

EXPOSE 8096

ENV MOBILE_HOST=0.0.0.0
ENV MOBILE_PORT=8096

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8096/api/v1/health || exit 1

ENTRYPOINT ["./uim-mobile-platform-service"]
