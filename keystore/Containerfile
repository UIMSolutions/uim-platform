# Multi-stage build for Keystore Service
# Compatible with Podman and Docker

# Stage 1: Build
FROM dlang2/ldc-ubuntu:1.40.1 AS builder

WORKDIR /app

COPY dub.sdl dub.selections.json ./
COPY source/ source/

RUN dub build --build=release --config=defaultRun

# Stage 2: Runtime
FROM ubuntu:24.04

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

RUN useradd --system --no-create-home appuser

WORKDIR /app

COPY --from=builder /app/build/uim-keystore-platform-service .

USER appuser

EXPOSE 8115

ENV KEYSTORE_HOST=0.0.0.0
ENV KEYSTORE_PORT=8115

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8115/api/v1/health || exit 1

ENTRYPOINT ["./uim-keystore-platform-service"]
